#---------------ARMSTRONG------------

num = int(input("Enter Any No: "))
temp = num
power = len(str(num))
total = 0
while num > 0:
	digit = num % 10
	total = total + digit ** power
	num = num // 10
if total == temp:
	print(f"{total} Is Armstrong Number")
else:
	print(f"{total} Is Not Armstrong Number")

