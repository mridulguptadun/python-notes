#Palindrome Number First Method

num = int(input("Enter a number: "))
temp = num
reverse = 0
while num > 0:
    digit = num % 10
    reverse = reverse * 10 + digit
    num = num // 10
if temp == reverse:
    print("Palindrome Number")
else:
    print("Not a Palindrome Number")

#Palindrome Number Second Method

num = input("Enter a number: ")
if num == num[::-1]:
    print("Palindrome Number")
else:
    print("Not a Palindrome Number")

