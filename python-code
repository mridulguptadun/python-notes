#Automorphic Number First Method
#Agar kisi number ka square usi number par end hota hai,to woh Automorphic Number kehlata hai.
""" 
5²  = 25      → end me 5 hai ✅
6²  = 36      → end me 6 hai ✅
25² = 625     → end me 25 hai ✅
76² = 5776    → end me 76 hai ✅
"""

num = int(input("Enter a number: "))
square = num * num
if str(square).endswith(str(num)):
    print("Automorphic Number")
else:
    print("Not Automorphic Number")

#Automorphic Number Second Method

num = int(input("Enter a number: "))
square = num * num
digits = len(str(num))
if square % (10 ** digits) == num:
    print("Automorphic Number")
else:
    print("Not Automorphic Number")

