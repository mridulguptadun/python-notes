#Perfect Number First Method
# Agar kisi number ke proper divisors (khud ko chhodkar) ka sum usi number ke barabar ho, to woh Perfect Number kehlata hai.
# Divisors:1, 2, 3
# Sum: 6

num = int(input("Enter a number: "))
total = 0
for i in range(1, num):
    if num % i == 0:
        total += i
if total == num:
    print("Perfect Number")
else:
    print("Not Perfect Number")

#Perfect Number Second Method

num = int(input("Enter a number: "))
i = 1
total = 0
while i < num:
    if num % i == 0:
        total += i
    i += 1
if total == num:
    print("Perfect Number")
else:
    print("Not Perfect Number")

