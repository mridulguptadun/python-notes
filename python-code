#Neon Number First Method
# Agar kisi number ke square ke digits ka sum usi number ke equal ho, to woh Neon Number kehlata hai.
# 9² = 81 => 8 + 1 = 9

num = int(input("Enter a number: "))
square = num * num
total = 0
while square > 0:
    digit = square % 10
    total += digit
    square = square // 10
if total == num:
    print("Neon Number")
else:
    print("Not Neon Number")

