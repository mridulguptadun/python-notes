#Strong Number First Method
# Agar kisi number ke har digit ke factorial ka sum usi number ke equal ho, to woh Strong Number kehlata hai.
# 145

num = int(input("Enter a number: "))
temp = num
total = 0
while num > 0:
    digit = num % 10
    fact = 1
    for i in range(1, digit + 1):
        fact *= i

    total += fact
    num = num // 10
if total == temp:
    print("Strong Number")
else:
    print("Not Strong Number")

#Strong Number Second Method

from math import factorial
num = int(input("Enter a number: "))
temp = num
total = 0
while num > 0:
    digit = num % 10
    total += factorial(digit)
    num = num // 10
if total == temp:
    print("Strong Number")
else:
    print("Not Strong Number")

